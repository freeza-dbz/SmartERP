datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Company {
  id               Int               @id @default(autoincrement())
  name             String
  address          String?
  state            String?
  gstNumber        String?
  financialYear    String?
  contactNumber    String?
  email            String?
  users            User[]
  ledgers          Ledger[]
  units            Unit[]
  stockGroups      StockGroup[]
  stockItems       StockItem[]
  purchaseVouchers PurchaseVoucher[]
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])
}

enum LedgerType {
  CUSTOMER
  SUPPLIER
  BANK
  CASH
  ASSET
  LIABILITY
  INCOME
  EXPENSE
}

model Ledger {
  id               Int               @id @default(autoincrement())
  name             String
  type             LedgerType
  openingBalance   Float
  currentBalance   Float
  companyId        Int
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseVouchers PurchaseVoucher[]
}

model Unit {
  id         Int         @id @default(autoincrement())
  name       String
  shortName  String
  companyId  Int
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockItems StockItem[]
}

model StockGroup {
  id         Int          @id @default(autoincrement())
  name       String
  parentId   Int?
  companyId  Int
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent     StockGroup?  @relation("StockGroupHierarchy", fields: [parentId], references: [id])
  children   StockGroup[] @relation("StockGroupHierarchy")
  stockItems StockItem[]
}

model StockItem {
  id                   Int                   @id @default(autoincrement())
  name                 String
  sku                  String?
  purchasePrice        Float
  sellingPrice         Float
  gstRate              Float
  openingStock         Float
  currentStock         Float
  unitId               Int
  unit                 Unit                  @relation(fields: [unitId], references: [id])
  groupId              Int
  stockGroup           StockGroup            @relation(fields: [groupId], references: [id])
  companyId            Int
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseVoucherItems PurchaseVoucherItem[]
}

model PurchaseVoucher {
  id          Int                   @id @default(autoincrement())
  voucherNo   String
  date        DateTime
  totalAmount Float
  supplierId  Int
  supplier    Ledger                @relation(fields: [supplierId], references: [id])
  items       PurchaseVoucherItem[]
  companyId   Int
  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model PurchaseVoucherItem {
  id        Int             @id @default(autoincrement())
  quantity  Float
  rate      Float
  voucher   PurchaseVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  voucherId Int
  item      StockItem       @relation(fields: [itemId], references: [id])
  itemId    Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}