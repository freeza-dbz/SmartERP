generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LedgerType {
  CUSTOMER
  SUPPLIER
  BANK
  CASH
  ASSET
  LIABILITY
  INCOME
  EXPENSE
}

model Company {
  id               Int               @id @default(autoincrement())
  userId           Int
  name             String            @db.VarChar(255)
  address          String?
  gstNumber        String?           @db.VarChar(20)
  state            String?           @db.VarChar(100)
  financialYear    String            @db.VarChar(20)
  createdAt        DateTime?         @default(now()) @db.Timestamp(6)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ledgers          Ledger[]
  purchaseVouchers PurchaseVoucher[]
  salesVouchers    SalesVoucher[]
  stockGroups      StockGroup[]
  stockItems       StockItem[]
  units            Unit[]
}

model Ledger {
  id                         Int               @id @default(autoincrement())
  name                       String
  type                       LedgerType
  openingBalance             Decimal           @default(0) @db.Decimal(12, 2)
  currentBalance             Decimal           @default(0) @db.Decimal(12, 2)
  isSystem                   Boolean           @default(false)
  companyId                  Int
  company                    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseVouchers           PurchaseVoucher[]
  salesVouchers              SalesVoucher[]
}

model PurchaseVoucher {
  id          Int                   @id @default(autoincrement())
  voucherNo   String                @db.VarChar(50)
  date        DateTime              @db.Date
  totalAmount Decimal               @db.Decimal(12, 2)
  companyId   Int
  supplierId  Int
  items       PurchaseVoucherItem[]
  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier    Ledger                @relation(fields: [supplierId], references: [id], onDelete: NoAction)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model PurchaseVoucherItem {
  id        Int             @id @default(autoincrement())
  quantity  Decimal         @db.Decimal(12, 2)
  rate      Decimal         @db.Decimal(12, 2)
  amount    Decimal?        @db.Decimal(12, 2)
  voucherId Int
  itemId    Int
  voucher   PurchaseVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  item      StockItem       @relation(fields: [itemId], references: [id], onDelete: NoAction)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model SalesVoucher {
  id          Int                @id @default(autoincrement())
  invoiceNo   String             @db.VarChar(50)
  invoiceDate DateTime           @db.Date
  totalAmount Decimal            @db.Decimal(12, 2)
  companyId   Int
  customerId  Int
  items       SalesVoucherItem[]
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer    Ledger             @relation(fields: [customerId], references: [id], onDelete: NoAction)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model SalesVoucherItem {
  id        Int          @id @default(autoincrement())
  quantity  Decimal      @db.Decimal(12, 2)
  rate      Decimal      @db.Decimal(12, 2)
  amount    Decimal?     @db.Decimal(12, 2)
  voucherId Int
  itemId    Int
  voucher   SalesVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  item      StockItem    @relation(fields: [itemId], references: [id], onDelete: NoAction)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model StockGroup {
  id         Int          @id @default(autoincrement())
  name       String
  parentId   Int?
  parent     StockGroup?  @relation("GroupToParent", fields: [parentId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  children   StockGroup[] @relation("GroupToParent")
  companyId  Int
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockItems StockItem[]
}

model StockItem {
  id            Int            @id @default(autoincrement())
  companyId     Int
  name          String
  sku           String?        @db.VarChar(100)
  purchasePrice Decimal        @default(0) @db.Decimal(12, 2)
  sellingPrice  Decimal        @default(0) @db.Decimal(12, 2)
  gstRate       Int            @default(0) // Store as a whole number, e.g., 18 for 18%
  openingStock  Decimal        @default(0) @db.Decimal(12, 2)
  currentStock  Decimal        @default(0) @db.Decimal(12, 2)
  unitId        Int
  unit          Unit           @relation(fields: [unitId], references: [id])
  groupId       Int
  stockGroup    StockGroup     @relation(fields: [groupId], references: [id])
  purchaseVoucherItems PurchaseVoucherItem[]
  salesVoucherItems    SalesVoucherItem[]
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Unit {
  id         Int         @id @default(autoincrement())
  companyId  Int
  name       String // e.g., "Pieces"
  shortName  String // e.g., "PCS"
  stockItems StockItem[]
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model User {
  id        Int       @id @default(autoincrement())
  fullName  String    @db.VarChar(100)
  email     String    @unique @db.VarChar(255)
  password  String    @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @db.Timestamp(6)
  username  String?
  companies Company[]
}
